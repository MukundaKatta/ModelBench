# ModelBench Configuration
# Copy this file to .env and adjust as needed

# Default number of benchmark iterations
MODELBENCH_ITERATIONS=100

# Default throughput measurement duration (seconds)
MODELBENCH_THROUGHPUT_DURATION=10.0

# Warmup iterations before benchmarking
MODELBENCH_WARMUP_ITERATIONS=5

# Output directory for exported results
MODELBENCH_OUTPUT_DIR=benchmark_results

# Log level (DEBUG, INFO, WARNING, ERROR)
MODELBENCH_LOG_LEVEL=INFO
